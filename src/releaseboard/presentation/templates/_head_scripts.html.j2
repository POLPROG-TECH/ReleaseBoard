<script>
/* i18n — locale persistence: redirect to stored locale if no explicit ?lang= */
(function() {
  var stored = localStorage.getItem('rb_locale');
  if (stored && !new URLSearchParams(window.location.search).has('lang')) {
    var url = new URL(window.location.href);
    url.searchParams.set('lang', stored);
    window.location.replace(url.toString());
  }
})();
</script>
