/* ===== ReleasePilot Wizard Styles ===== */

/* Prepare Release action button in table rows */
.rp-action-btn {
  display: inline-flex; align-items: center; gap: 3px;
  padding: 4px 10px; border: 1px solid var(--primary); border-radius: 6px;
  background: var(--bg-card); color: var(--primary); font-size: .78rem; font-weight: 600;
  cursor: pointer; transition: all .15s ease; font-family: var(--font); white-space: nowrap;
}
.rp-action-btn:hover {
  background: var(--primary); color: var(--text-inverse);
}
.rp-action-btn .rp-icon { font-size: .9rem; line-height: 1; }

/* Overlay */
.rp-wizard-overlay {
  position: fixed; inset: 0; z-index: 10000;
  background: rgba(0,0,0,.5); backdrop-filter: blur(4px);
  display: none; align-items: center; justify-content: center;
}
.rp-wizard-overlay.active { display: flex; }

/* Panel */
.rp-wizard-panel {
  background: var(--bg-primary); border-radius: 16px;
  width: min(760px, calc(100vw - 40px)); max-height: calc(100vh - 60px);
  display: flex; flex-direction: column;
  box-shadow: 0 25px 60px rgba(0,0,0,.25);
  border: 1px solid var(--border);
  overflow: hidden;
}

/* Header */
.rp-wizard-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 24px; border-bottom: 1px solid var(--border);
}
.rp-wizard-header h2 { margin: 0; font-size: 1.15rem; font-weight: 700; }
.rp-wizard-close {
  width: 32px; height: 32px; border-radius: 8px; border: none;
  background: var(--bg-secondary); color: var(--text-secondary);
  cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center;
  transition: all .15s ease;
}
.rp-wizard-close:hover { background: var(--bg-tertiary); color: var(--text-primary); }

/* Step tabs */
.rp-wizard-steps {
  display: flex; gap: 0; padding: 0 24px; border-bottom: 1px solid var(--border);
  background: var(--bg-secondary); overflow-x: auto; -webkit-overflow-scrolling: touch;
}
.rp-wizard-step-tab {
  display: flex; align-items: center; gap: 8px;
  padding: 12px 16px; font-size: .82rem; font-weight: 500;
  color: var(--text-tertiary); cursor: default;
  border-bottom: 2px solid transparent; transition: all .15s ease;
}
.rp-wizard-step-tab.active {
  color: var(--primary); border-bottom-color: var(--primary); font-weight: 600;
}
.rp-wizard-step-tab.completed { color: var(--text-secondary); }
.rp-wizard-step-tab.completed .rp-step-num {
  background: var(--tertiary); color: var(--text-inverse);
}
.rp-step-num {
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .72rem; font-weight: 700;
  background: var(--bg-tertiary); color: var(--text-tertiary);
  transition: all .15s ease;
}
.rp-wizard-step-tab.active .rp-step-num {
  background: var(--primary); color: var(--text-inverse);
}

/* Body */
.rp-wizard-body {
  flex: 1; overflow-y: auto; padding: 24px;
}
.rp-wizard-step-content { display: none; }
.rp-wizard-step-content.active { display: block; }
.rp-step-desc {
  margin: 0 0 20px; color: var(--text-secondary); font-size: .88rem; line-height: 1.5;
}

/* Context grid (Step 1) */
.rp-context-grid {
  display: flex; flex-direction: column; gap: 0;
  border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
}
.rp-context-row {
  display: flex; align-items: center; padding: 10px 16px;
  border-bottom: 1px solid var(--border); font-size: .88rem;
}
.rp-context-row:last-child { border-bottom: none; }
.rp-context-label {
  width: 160px; flex-shrink: 0; font-weight: 600; color: var(--text-secondary); font-size: .82rem;
}
.rp-context-value { color: var(--text-primary); }
.rp-context-mono { font-family: monospace; font-size: .84rem; }

/* Form grid (Step 2) */
.rp-form-grid { display: flex; flex-direction: column; gap: 16px; }
.rp-form-row label { display: block; font-size: .82rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 4px; }
.rp-form-row-pair { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.rp-input, .rp-select, .rp-textarea {
  width: 100%; padding: 8px 12px; border: 1px solid var(--border); border-radius: 8px;
  font-size: .88rem; font-family: var(--font);
  background: var(--bg-primary); color: var(--text-primary);
  box-sizing: border-box; transition: border-color .15s ease;
}
.rp-input:focus, .rp-select:focus, .rp-textarea:focus {
  outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px var(--ring);
}
.rp-input-mono { font-family: monospace; }
.rp-textarea { resize: vertical; min-height: 60px; }
.rp-checkbox-row label {
  display: flex; align-items: center; gap: 8px; cursor: pointer;
  font-weight: 500; color: var(--text-primary); margin-bottom: 0;
}
.rp-checkbox-row input[type="checkbox"] {
  width: 16px; height: 16px; accent-color: var(--primary);
}
.rp-field-error {
  display: none; font-size: .78rem; color: #dc2626; margin-top: 3px;
}
.rp-inline-error {
  margin-top: 12px; padding: 10px 14px; border-radius: 8px;
  background: rgba(239, 68, 68, .08); border: 1px solid rgba(239, 68, 68, .35);
  color: #dc2626; font-size: .84rem; line-height: 1.5;
}
.rp-field-hint {
  font-size: .76rem; color: var(--text-tertiary); margin-top: 3px;
  min-height: 1em; line-height: 1.3;
}

/* Preview (Step 3) */
.rp-generating {
  text-align: center; padding: 40px 20px;
}
.rp-generating h3 { margin: 16px 0 8px; font-size: 1rem; }
.rp-generating p { color: var(--text-secondary); font-size: .88rem; }
.rp-spinner {
  width: 40px; height: 40px; border: 3px solid var(--border);
  border-top-color: var(--primary); border-radius: 50%;
  animation: rp-spin 0.8s linear infinite;
  margin: 0 auto;
}
@keyframes rp-spin { to { transform: rotate(360deg); } }

.rp-gen-error {
  text-align: center; padding: 40px 20px;
}
.rp-gen-error-icon { font-size: 2rem; margin-bottom: 8px; }
.rp-gen-error h3 { margin: 8px 0; color: #dc2626; }
.rp-gen-error p { color: var(--text-secondary); font-size: .88rem; margin-bottom: 16px; }

.rp-preview-stats {
  display: flex; gap: 16px; margin-bottom: 16px;
}
.rp-stat {
  flex: 1; text-align: center; padding: 12px; border-radius: 10px;
  background: var(--bg-secondary); border: 1px solid var(--border);
}
.rp-stat-value { display: block; font-size: 1.3rem; font-weight: 700; color: var(--primary); }
.rp-stat-label { display: block; font-size: .76rem; color: var(--text-tertiary); margin-top: 2px; }

.rp-preview-warnings {
  padding: 10px 14px; border-radius: 8px; margin-bottom: 16px;
  background: rgba(245, 158, 11, .08); border: 1px solid rgba(245, 158, 11, .35);
  color: #b8860b; font-size: .84rem; line-height: 1.5;
}

.rp-preview-content-wrap {
  border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
}
.rp-preview-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 14px; background: var(--bg-secondary); border-bottom: 1px solid var(--border);
  font-size: .82rem; font-weight: 600; color: var(--text-secondary);
}
.rp-btn-sm {
  padding: 4px 10px; border: 1px solid var(--border); border-radius: 6px;
  background: var(--bg-primary); color: var(--text-secondary); font-size: .78rem;
  cursor: pointer; font-family: var(--font); transition: all .15s ease;
}
.rp-btn-sm:hover { background: var(--bg-tertiary); color: var(--text-primary); }
.rp-preview-content {
  padding: 16px; font-family: monospace; font-size: .84rem; line-height: 1.6;
  white-space: pre-wrap; min-height: 200px; max-height: 400px; overflow-y: auto;
  color: var(--text-primary); background: var(--bg-primary);
  outline: none;
}
.rp-preview-content.rp-editable {
  background: rgba(251, 100, 0, .03); border: 2px solid var(--primary);
  border-top: none;
}

/* Confirm (Step 4) */
.rp-confirm-box { margin-bottom: 16px; }
.rp-confirm-box h3 { margin: 0 0 8px; font-size: 1rem; }
.rp-confirm-box p { color: var(--text-secondary); font-size: .88rem; margin: 0 0 16px; }
.rp-confirm-grid {
  border: 1px solid var(--border); border-radius: 10px; overflow: hidden;
}
.rp-confirm-row {
  display: flex; align-items: center; padding: 10px 16px;
  border-bottom: 1px solid var(--border); font-size: .88rem;
}
.rp-confirm-row:last-child { border-bottom: none; }
.rp-confirm-row span:first-child { width: 130px; flex-shrink: 0; color: var(--text-secondary); font-size: .82rem; }
.rp-confirm-row strong { color: var(--text-primary); }
.rp-confirm-warnings {
  margin-top: 12px; padding: 10px 14px; border-radius: 8px;
  background: rgba(245, 158, 11, .08); border: 1px solid rgba(245, 158, 11, .35);
  color: #b8860b; font-size: .84rem;
}

/* Success */
.rp-success {
  text-align: center; padding: 20px;
}
.rp-success-icon {
  width: 56px; height: 56px; border-radius: 50%; margin: 0 auto 12px;
  background: var(--tertiary-light); color: var(--tertiary);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem; font-weight: 700;
}
.rp-success h3 { margin: 0 0 8px; color: var(--tertiary); }
.rp-success p { color: var(--text-secondary); font-size: .88rem; margin: 0 0 20px; }
.rp-success-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }

.rp-toast {
  margin-top: 12px; padding: 6px 14px; border-radius: 6px;
  background: var(--bg-secondary); color: var(--text-secondary);
  font-size: .82rem; display: inline-block;
  animation: rp-fade-in .2s ease;
}
@keyframes rp-fade-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

/* Footer */
.rp-wizard-footer {
  display: flex; align-items: center; padding: 14px 24px; gap: 12px;
  border-top: 1px solid var(--border); background: var(--bg-secondary);
}

/* Buttons */
.rp-btn {
  padding: 8px 18px; border-radius: 8px; font-size: .88rem; font-weight: 600;
  font-family: var(--font); cursor: pointer; border: 1px solid var(--border);
  background: var(--bg-primary); color: var(--text-primary);
  transition: all .15s ease;
}
.rp-btn:hover { background: var(--bg-tertiary); }
.rp-btn.primary {
  background: var(--primary); color: var(--text-inverse); border-color: var(--primary);
}
.rp-btn.primary:hover { filter: brightness(1.08); }
.rp-btn.primary.generate { background: var(--primary); border-color: var(--primary); }
.rp-btn.primary.generate:hover { filter: brightness(1.08); }
.rp-btn.primary.confirm { background: var(--primary); border-color: var(--primary); }
.rp-btn.primary.confirm:hover { filter: brightness(1.08); }

/* Responsive */
@media (max-width: 600px) {
  .rp-wizard-panel { width: calc(100vw - 16px); max-height: calc(100vh - 20px); border-radius: 12px; }
  .rp-form-row-pair { grid-template-columns: 1fr; }
  .rp-preview-stats { flex-direction: column; }
  .rp-wizard-steps { overflow-x: auto; }
  .rp-wizard-step-tab { padding: 10px 10px; font-size: .76rem; }
  .rp-context-label { width: 120px; }
}

/* PDF / DOCX binary preview */
.rp-pdf-preview {
  width: 100%; height: 400px; border: 1px solid var(--border); border-radius: 8px;
  background: var(--bg-secondary);
}
.rp-binary-placeholder {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px; padding: 48px 24px;
  background: var(--bg-secondary); border: 2px dashed var(--border); border-radius: 10px;
  text-align: center; color: var(--text-secondary);
}
.rp-binary-icon { font-size: 3rem; line-height: 1; }
.rp-binary-placeholder p { margin: 0; font-size: .9rem; }

/* --- Dark Theme Overrides --- */
[data-theme="dark"] .rp-inline-error { background: rgba(248,113,113,.08); border-color: rgba(248,113,113,.35); color: #f87171; }
[data-theme="dark"] .rp-field-error { color: #f87171; }
[data-theme="dark"] .rp-gen-error h3 { color: #f87171; }
[data-theme="dark"] .rp-preview-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
[data-theme="dark"] .rp-confirm-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
@media (prefers-color-scheme: dark) {
  [data-theme="system"] .rp-inline-error { background: rgba(248,113,113,.08); border-color: rgba(248,113,113,.35); color: #f87171; }
  [data-theme="system"] .rp-field-error { color: #f87171; }
  [data-theme="system"] .rp-gen-error h3 { color: #f87171; }
  [data-theme="system"] .rp-preview-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
  [data-theme="system"] .rp-confirm-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
}

/* --- Midnight Theme Overrides --- */
[data-theme="midnight"] .rp-wizard-panel { border-color: var(--border); box-shadow: 0 25px 60px rgba(0,0,0,.5); }
[data-theme="midnight"] .rp-btn.primary { background: var(--primary); color: var(--text-inverse); border-color: var(--primary); }
[data-theme="midnight"] .rp-btn.primary:hover { background: color-mix(in srgb, var(--primary) 85%, #000); }
[data-theme="midnight"] .rp-btn.primary.generate { background: var(--primary); border-color: var(--primary); }
[data-theme="midnight"] .rp-btn.primary.generate:hover { filter: brightness(1.08); }
[data-theme="midnight"] .rp-btn.primary.confirm { background: var(--primary); border-color: var(--primary); }
[data-theme="midnight"] .rp-btn.primary.confirm:hover { filter: brightness(1.08); }
[data-theme="midnight"] .rp-stat-value { color: var(--primary); }
[data-theme="midnight"] .rp-action-btn { border-color: var(--primary); color: var(--primary); }
[data-theme="midnight"] .rp-action-btn:hover { background: var(--primary); color: var(--text-inverse); }
[data-theme="midnight"] .rp-spinner { border-top-color: var(--primary); }
[data-theme="midnight"] .rp-success-icon { background: color-mix(in srgb, var(--tertiary) 12%, transparent); color: var(--tertiary); }
[data-theme="midnight"] .rp-success h3 { color: var(--tertiary); }
[data-theme="midnight"] .rp-inline-error { background: rgba(248,113,113,.08); border-color: rgba(248,113,113,.35); color: #f87171; }
[data-theme="midnight"] .rp-preview-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
[data-theme="midnight"] .rp-confirm-warnings { background: rgba(251,191,36,.06); border-color: rgba(251,191,36,.3); color: #fbbf24; }
[data-theme="midnight"] .rp-context-grid { border-color: var(--border); }
[data-theme="midnight"] .rp-context-row { border-bottom-color: var(--border); }
[data-theme="midnight"] .rp-preview-content-wrap { border-color: var(--border); }
[data-theme="midnight"] .rp-preview-content.rp-editable { border-color: var(--primary); background: color-mix(in srgb, var(--primary) 3%, transparent); }
